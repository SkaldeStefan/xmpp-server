# Docker Images
POSTGRES_IMAGE=postgres:16.9
PROSODY_IMAGE=prosodyim/prosody:0.12
COTURN_IMAGE=coturn/coturn:4.6.3
TRAEFIK_CERTS_DUMPER_IMAGE=ghcr.io/ldez/traefik-certs-dumper:v2.10

# Database
POSTGRES_DB=prosody
POSTGRES_USER=prosody

# Backup
BACKUP_RETENTION_DAYS=14

# File Upload (XEP-0363)
UPLOAD_MAX_BYTES=20971520

# Traefik
TRAEFIK_EXTERNAL=false
TRAEFIK_CERT_RESOLVER=letsencrypt
