# Copy to .env.local and fill in your values.

# Deployment paths
PROJECT_DIR=.
SECRETS_DIR=./secrets

# XMPP
PROSODY_DOMAIN=xmpp.example.com
PROSODY_ADMIN_JID=admin@xmpp.example.com

# File Upload (XEP-0363) – Hetzner Storage Box (WebDAV)
UPLOAD_DOMAIN=upload.example.com
STORAGE_BOX_URL=https://u123456.your-storagebox.de
STORAGE_BOX_USER=u123456

# TURN/STUN (Audio/Video-Calls)
PROSODY_TURN_HOST=xmpp.example.com

# Traefik
TRAEFIK_NETWORK=traefik
TRAEFIK_ACME_JSON=/path/to/traefik/acme.json
